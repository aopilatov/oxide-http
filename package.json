{
  "name": "@oxide/http",
  "version": "0.0.0",
  "description": "Быстрый HTTP/1.1 + HTTP/2 сервер для Node.js на Rust (napi-rs)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "oxide-http",
    "packageName": "@oxide/http",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "scripts": {
    "build": "napi build --platform",
    "build:release": "napi build --platform --release",
    "artifacts": "napi artifacts",
    "prepublishOnly": "tsc && napi prepublish -t npm",
    "format": "cargo fmt",
    "lint": "cargo clippy -- -D warnings && npm run typecheck",
    "test": "node --test \"__test__/**/*.test.ts\"",
    "build:ts": "tsc",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.1.1",
    "@valibot/to-json-schema": "^1.7.1",
    "typescript": "^7.0.2",
    "valibot": "^1.4.2"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "dist/"
  ]
}

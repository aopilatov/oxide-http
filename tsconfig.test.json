{
  // Type checking for the tests: they are not part of the package build (the build
  // config's rootDir is js/), but they still need checking.
  //
  // The library compiles under maximum strictness (0 errors). A few flags are relaxed
  // here on purpose — they demand annotations in the tests' internal helpers
  // (`function up(build)`) without giving anything back. The important part remains:
  // contextual typing from the route overloads works regardless of noImplicitAny, so a
  // typo in the public API (`c.jsonn`, an unknown config key, a wrong hook signature)
  // is still a compile error in tests.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    // Node always executes tests and fixtures as ESM (it detects this from the syntax).
    // The build config targets CJS, so we declare the module system explicitly here —
    // otherwise TS forbids import.meta and top-level await.
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["js/**/*.ts", "__test__/**/*.ts"]
}
